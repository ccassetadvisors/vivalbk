{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "echo \"Static site — nothing to build\"",
  "installCommand": "echo \"No dependencies to install\"",
  "outputDirectory": ".",
  "headers": [
    {
      "source": "/assets/fonts/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
